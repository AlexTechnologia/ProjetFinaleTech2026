<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lure Discrimination Test</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen selection:bg-blue-500/30">

  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useMemo } = React;

    // --- HELPER FUNCTION ---
    // Helper to shuffle the lure options (but NOT the original) in a legitimate test.
    // However, to replicate the static grid from the user image, we will hard-code the grid.
    const getGridOptions = () => {
      return [
        { id: 'lure1', type: 'color_br_black', label: 'Option 1' },
        { id: 'original', type: 'original', label: 'Option 2' },
        { id: 'lure2', type: 'swap_top_bot', label: 'Option 3' },
        { id: 'lure3', type: 'missing_link_top', label: 'Option 4' },
      ];
    };

    // --- INLINE ICON COMPONENTS ---
    const BrainCircuit = ({ size = 24, className = "" }) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
        <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/>
        <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/>
        <path d="M12 5v14"/><path d="M12 12h6"/>
      </svg>
    );

    const Play = ({ size = 24, className = "", fill = "none" }) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill={fill} stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
        <polygon points="6 3 20 12 6 21 6 3"/>
      </svg>
    );

    const CheckCircle2 = ({ size = 24, className = "", strokeWidth = 2.5 }) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={strokeWidth} strokeLinecap="round" strokeLinejoin="round" className={className}>
        <circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>
      </svg>
    );

    const XCircle = ({ size = 24, className = "", strokeWidth = 2.5 }) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={strokeWidth} strokeLinecap="round" strokeLinejoin="round" className={className}>
        <circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
      </svg>
    );

    const Eye = ({ size = 24, className = "" }) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
        <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
    );

    const RefreshCw = ({ size = 24, className = "" }) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/>
      </svg>
    );

    // --- REDESIGNED 6-NODE NEURAL NETWORK SVG COMPONENT ---
    const NeuralNetwork = ({ type, showLabel }) => {
      // Base standard node colors for a complete 6-node pattern
      // Matching images as closely as possible using Tailwind color values
      let top_blue = '#60a5fa';   // blue-400
      let tr_green = '#22c55e';   // green-500
      let br_orange = '#f97316';  // orange-500
      let bot_red = '#f87171';    // red-400 (closer to pink-red in image)
      let bl_purple = '#a855f7';  // purple-500
      let tl_pink = '#ec4899';    // pink-500 (magenta)
      
      // Base standard radial links (true = exists, false = missing)
      let link_top_center = true;
      let link_tr_center = true;
      let link_br_center = true;
      let link_bot_center = true;
      let link_bl_center = true;
      let link_tl_center = true;

      // Apply Lures (Modifications based on images)
      let errorText = "";
      if (type === 'color_br_black') {
        br_orange = '#000000'; // Black Lure node
        errorText = "Wrong Node Color (Black vs Orange)";
      }
      if (type === 'swap_top_bot') {
        // Swap colors of Top (Blue) and Bottom (Red) nodes
        [top_blue, bot_red] = [bot_red, top_blue];
        errorText = "Swapped Node Colors (Top/Bot)";
      }
      if (type === 'missing_link_top') {
        link_top_center = false; // Missing the link from Top (Blue) node to center
        errorText = "Missing Neural Link";
      }

      const isOriginal = type === 'original';

      return (
        <div className="relative w-full aspect-square flex flex-col items-center">
          <svg viewBox="0 0 200 200" className="w-full h-full bg-slate-900 rounded-xl shadow-inner border border-slate-700">
            {/* --- Radial Links / Synapses connecting all 6 nodes to center --- */}
            <line x1="100" y1="100" x2="100" y2="30" stroke="#475569" strokeWidth="4" className={`${!link_top_center ? 'opacity-0' : ''}`} /> {/* Top */}
            <line x1="100" y1="100" x2="161" y2="65" stroke="#475569" strokeWidth="4" className={`${!link_tr_center ? 'opacity-0' : ''}`} /> {/* Top-Right */}
            <line x1="100" y1="100" x2="161" y2="135" stroke="#475569" strokeWidth="4" className={`${!link_br_center ? 'opacity-0' : ''}`} /> {/* Bottom-Right */}
            <line x1="100" y1="100" x2="100" y2="170" stroke="#475569" strokeWidth="4" className={`${!link_bot_center ? 'opacity-0' : ''}`} /> {/* Bottom */}
            <line x1="100" y1="100" x2="39" y2="135" stroke="#475569" strokeWidth="4" className={`${!link_bl_center ? 'opacity-0' : ''}`} /> {/* Bottom-Left */}
            <line x1="100" y1="100" x2="39" y2="65" stroke="#475569" strokeWidth="4" className={`${!link_tl_center ? 'opacity-0' : ''}`} /> {/* Top-Left */}
            
            {/* Subtle center marker */}
            <circle cx="100" cy="100" r="5" fill="#e2e8f0" />

            {/* --- Outer Ring Links --- (Optional, can be hidden for simplicity as not visible in images)
            <line x1="100" y1="30" x2="161" y2="65" stroke="#334155" strokeWidth="1" strokeDasharray="4 4" />  
            <line x1="161" y1="65" x2="161" y2="135" stroke="#334155" strokeWidth="1" strokeDasharray="4 4" />
            <line x1="161" y1="135" x2="100" y2="170" stroke="#334155" strokeWidth="1" strokeDasharray="4 4" />
            <line x1="100" y1="170" x2="39" y2="135" stroke="#334155" strokeWidth="1" strokeDasharray="4 4" />
            <line x1="39" y1="135" x2="39" y2="65" stroke="#334155" strokeWidth="1" strokeDasharray="4 4" />
            <line x1="39" y1="65" x2="100" y2="30" stroke="#334155" strokeWidth="1" strokeDasharray="4 4" />
            --- */}

            {/* --- Nodes / Neurons --- (A complete hexagonal ring) */}
            <circle cx="100" cy="30" r="15" fill={top_blue} /> {/* Top */}
            <circle cx="161" cy="65" r="15" fill={tr_green} /> {/* Top-Right */}
            <circle cx="161" cy="135" r="15" fill={br_orange} /> {/* Bottom-Right */}
            <circle cx="100" cy="170" r="15" fill={bot_red} /> {/* Bottom */}
            <circle cx="39" cy="135" r="15" fill={bl_purple} /> {/* Bottom-Left */}
            <circle cx="39" cy="65" r="15" fill={tl_pink} /> {/* Top-Left */}
          </svg>

          {/* Result Overlays */}
          {showLabel && (
            <div className={`absolute bottom-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full text-sm font-bold whitespace-nowrap shadow-lg ${isOriginal ? 'bg-green-500/90 text-slate-950' : 'bg-red-500/90 text-white'}`}>
              {isOriginal ? 'The Original' : errorText}
            </div>
          )}
          {showLabel && isOriginal && (
            <div className="absolute top-4 right-4 text-green-400 bg-slate-950 rounded-full">
              <CheckCircle2 size={32} />
            </div>
          )}
          {showLabel && !isOriginal && (
            <div className="absolute top-4 right-4 text-red-400 bg-slate-950 rounded-full">
              <XCircle size={32} />
            </div>
          )}
        </div>
      );
    };

    // --- MAIN APPLICATION COMPONENT ---
    function App() {
      const [step, setStep] = useState('intro'); // intro, memorize, test, result
      const [timeLeft, setTimeLeft] = useState(3);
      // Generate randomized options, but for strict adherence to user image, we'll keep the grid order from image_3.png
      const [options, setOptions] = useState(() => getGridOptions());
      const [score, setScore] = useState(0);
      const [round, setRound] = useState(1);

      // Handle the 3-second memory countdown
      useEffect(() => {
        let timer;
        if (step === 'memorize' && timeLeft > 0) {
          timer = setInterval(() => {
            setTimeLeft((prev) => prev - 1);
          }, 1000);
        } else if (step === 'memorize' && timeLeft === 0) {
          setStep('test');
        }
        return () => clearInterval(timer);
      }, [step, timeLeft]);

      const startTest = () => {
        setTimeLeft(3);
        setStep('memorize');
        // If a real game, you would set new random options here.
        // setOptions(shuffleArray(getGridOptions()));
      };

      const revealAnswer = () => {
        setStep('result');
        // Logic to track if Option 2 was chosen would go here.
        // setScore(prev => prev + 1); // Only for a fully functional game
      };

      const resetTest = () => {
        setRound(prev => prev + 1);
        setStep('intro');
      };

      return (
        <div className="min-h-screen bg-slate-950 text-slate-100 flex flex-col items-center p-8 font-sans selection:bg-blue-500/30">
          
          <div className="text-center mb-8 w-full max-w-5xl flex items-center justify-between border-b border-slate-800 pb-4">
            <div className="flex items-center gap-3">
              <BrainCircuit className="text-blue-500" size={32} />
              <h1 className="text-2xl font-extrabold tracking-tight text-white">Lure Discrimination Test</h1>
            </div>
            <div className="text-right">
              <p className="text-slate-400 text-sm font-semibold uppercase tracking-wider">Testing Working Memory Integrity</p>
              <p className="text-blue-400 text-sm font-mono">Round {round} | Score: {score}</p>
            </div>
          </div>

          <div className="w-full max-w-5xl flex-1 flex flex-col items-center justify-center">
            
            {step === 'intro' && (
              <div className="text-center bg-slate-900 border border-slate-800 p-12 rounded-3xl shadow-2xl max-w-2xl animate-in fade-in zoom-in duration-300">
                <Eye className="w-20 h-20 text-blue-500 mx-auto mb-6 opacity-90" />
                <h2 className="text-3xl font-bold mb-4 text-white tracking-tight">Are you sleep deprived?</h2>
                <p className="text-slate-400 mb-8 text-lg leading-relaxed">
                  You will see a complex neural network diagram for exactly <strong className="text-blue-400">3 seconds</strong>. 
                  Study the colors and synaptic connections carefully. Then, you must identify the exact original from a grid of three highly similar cognitive "lures".
                </p>
                <button 
                  onClick={startTest}
                  className="bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 px-10 rounded-full shadow-lg shadow-blue-600/30 hover:shadow-blue-500/50 hover:-translate-y-1 transition-all duration-300 flex items-center gap-3 mx-auto text-lg"
                >
                  <Play size={24} fill="currentColor" />
                  Begin 3-Second Flash
                </button>
              </div>
            )}

            {step === 'memorize' && (
              <div className="flex flex-col items-center animate-in fade-in zoom-in duration-300">
                <div className="text-8xl font-black text-blue-500 mb-10 tabular-nums animate-pulse drop-shadow-[0_0_15px_rgba(59,130,246,0.5)]">
                  {timeLeft}
                </div>
                <div className="w-96 h-96 border-4 border-dashed border-blue-500/30 rounded-3xl p-4 transition-all hover:border-blue-500 shadow-lg shadow-blue-500/20">
                  <NeuralNetwork type="original" showLabel={false} />
                </div>
              </div>
            )}

            {(step === 'test' || step === 'result') && (
              <div className="w-full animate-in fade-in slide-in-from-bottom-8 duration-500">
                <div className="text-center mb-10">
                  <h2 className="text-3xl font-bold text-white mb-3">Which one is the exact original?</h2>
                  <p className="text-slate-400 text-lg flex items-center justify-center gap-2">
                    <CheckCircle2 size={20} className="text-green-500" /> Did you spot the original neural pathway?
                  </p>
                </div>

                <div className="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
                  
                  {options.map((option, index) => {
                    const isOriginal = option.type === 'original';
                    const number = index + 1;
                    
                    // Style each card based on game state (Test vs Result) and selection
                    let cardStyle = "bg-slate-800/80 border-2 border-slate-700 hover:border-blue-500/50 cursor-pointer shadow-lg";
                    if (step === 'result') {
                      cardStyle = "cursor-default transition-all duration-500 ";
                      if (isOriginal) {
                        cardStyle += "bg-green-900/30 border-2 border-green-500 scale-105 shadow-[0_0_30px_rgba(34,197,94,0.3)] z-20";
                      } else {
                        cardStyle += "bg-slate-800/50 border-2 border-slate-800 scale-95 opacity-50";
                      }
                    }

                    return (
                      <div 
                        key={option.id}
                        className={`relative rounded-3xl p-3 transition-all duration-300 ${cardStyle}`}
                      >
                        {/* Number indicator from images */}
                        <div className={`absolute -top-5 -left-5 w-12 h-12 rounded-full flex items-center justify-center font-black text-2xl border-4 border-slate-950 z-30 shadow-lg transition-colors ${step === 'result' && isOriginal ? 'bg-green-500 text-slate-950' : 'bg-slate-700 text-slate-300'}`}>
                          {number}
                        </div>
                        
                        <NeuralNetwork type={option.type} showLabel={step === 'result'} />
                      </div>
                    );
                  })}

                </div>

                <div className="flex justify-center gap-6">
                  {step === 'test' && (
                    <button 
                      onClick={revealAnswer}
                      className="bg-green-600 hover:bg-green-500 text-white font-bold py-4 px-10 rounded-full shadow-lg transition-all flex items-center gap-3 text-lg"
                    >
                      <CheckCircle2 size={24} />
                      Reveal Answer
                    </button>
                  )}
                  {step === 'result' && (
                    <button 
                      onClick={resetTest}
                      className="bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 px-10 rounded-full shadow-lg hover:shadow-blue-500/30 transition-all flex items-center gap-3 text-lg hover:-translate-y-1"
                    >
                      <RefreshCw size={24} />
                      Start Next Round
                    </button>
                  )}
                </div>
              </div>
            )}

          </div>
        </div>
      );
    }

    // Render configuration for React 18 Dom Mounting
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
